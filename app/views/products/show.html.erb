<div class="container mt-4">
  <div class="row align-items-center">
    <!-- Product Image Section -->
    <div class="col-md-4 d-flex justify-content-center">
      <% if @product.images.attached? %>
        <%= image_tag @product.images.first, class: "img-thumbnail w-75 rounded shadow-sm", alt: @product.name %>
      <% else %>
        <img src="https://via.placeholder.com/150" class="img-thumbnail w-75 rounded shadow-sm" alt="No Image Available">
      <% end %>
    </div>

    <!-- Product Details Section -->
    <div class="col-md-8">
      <div class="card p-3 shadow-sm">
        <h5 class="fw-bold"><%= @product.name %></h5>
        <p class="mb-1"><strong>Description:</strong> <%= @product.description %></p>
        <p class="mb-1"><strong>Price:</strong> <span class="text-success">$<%= @product.price %></span></p>
        <p class="mb-1"><strong>Stock:</strong> <span class="badge bg-info"><%= @product.stock_quantity %></span></p>
        <p class="mb-1"><strong>Category:</strong> <span class="badge bg-secondary"><%= @product.category.name if @product.category %></span></p>

        <%= form_with url: add_to_cart_cart_path(product_id: @product.id), method: :post, local: true, class: "d-flex align-items-center mt-2" do |f| %>
          <%= f.number_field :quantity, value: 1, min: 1, class: "form-control w-25 me-2" %>
          <%= f.submit "Add to Cart", class: "btn btn-primary btn-sm" %>
        <% end %>

        <!-- Back & Edit Buttons -->
        <div class="mt-2">
          <%= link_to 'Back', products_path, class: 'btn btn-secondary btn-sm' %>
          <% if current_user&.admin? %>
            <%= link_to 'Edit', edit_product_path(@product), class: 'btn btn-warning btn-sm ms-2' %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>





