<h1 class="mb-4">Checkout</h1>

<%= form_with model: @order, url: orders_path, method: :post, local: true, class: "container card p-4 shadow-sm" do |f| %>
  <div class="mb-3">
    <%= f.label :customer_name, "Customer Name", class: "form-label fw-bold" %>
    <%= f.text_field :customer_name, value: current_user.name, class: "form-control", required: true %>
  </div>

  <div class="mb-3">
    <%= f.label :shipping_address, "Shipping Address", class: "form-label fw-bold" %>
    <%= f.text_area :shipping_address, class: "form-control", rows: 3, required: true %>
  </div>

  <div class="mb-3">
    <%= f.label :payment_method, "Select Payment Method", class: "form-label fw-bold" %>
    <%= f.select :payment_method, ['Cash on Delivery', 'Credit Card'], prompt: 'Select Payment Method', class: "form-select", required: true %>
  </div>

  <h3 class="mt-4">Order Summary</h3>
  <ul class="list-group mb-3">
    <% current_cart.each do |product_id, quantity| %>
      <% product = Product.find(product_id) %>
      <li class="list-group-item d-flex justify-content-between">
        <span><strong><%= product.name %></strong> - <%= quantity %> x <%= number_to_currency(product.price) %></span>
        <span><%= number_to_currency(product.price * quantity) %></span>
      </li>
    <% end %>
  </ul>

  <p class="fs-5 fw-bold">Total: <%= number_to_currency(current_cart.sum { |pid, qty| Product.find(pid).price * qty }) %></p>

  <%= f.submit "Place Order", class: "btn btn-success btn-lg w-100 mt-3" %>
<% end %>

