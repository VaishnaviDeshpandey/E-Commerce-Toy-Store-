<h1>Order History</h1>

<% if @orders.any? %>
  <table>
    <thead>
      <tr>
        <th>Order ID</th>
        <th>Customer Name</th>
        <th>Date</th>
        <th>Total Price</th>
        <th>Status</th>
        <th>Payment Status</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @orders.each do |order| %>
        <tr>
          <td><%= order.id %></td>
          <td><%= order.customer_name %></td>
          <td><%= order.created_at.strftime("%B %d, %Y") %></td>
          <td>$<%= order.total_price %></td>
          <td><%= order.status %></td>
          <td><%= order.payment_status %></td>
          <td><%= link_to "View", order_path(order), class: "btn btn-primary" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>You have not placed any orders yet.</p>
<% end %>
