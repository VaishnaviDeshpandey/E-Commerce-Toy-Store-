<h1 class="mb-4">Categories</h1>

<% if current_user&.admin? %>
  <%= link_to 'Add New Category', new_category_path, class: "btn btn-success mb-3" %>
<% end %>

<!-- Search and Filter -->
<div class="row mb-3">
  <div class="col-md-6">
    <%= form_with url: categories_path, method: :get, local: true, class: "d-flex" do |form| %>
      <%= form.text_field :query, value: params[:query], placeholder: "Search Category", class: "form-control me-2" %>
      <%= form.submit "Search", class: "btn btn-outline-primary" %>
    <% end %>  
  </div>

</div>

<!-- Categories Table -->
<table class="table table-striped table-hover">
  <thead class="table-dark">
    <tr>
      <th>Icon</th>
      <th>Name</th>
      <th>Product Count</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @categories.each do |category| %>
      <tr>
      <td>
      <% if category.icon.attached? %>
        <%= image_tag category.icon.variant(resize_to_limit: [40, 40]), class: "rounded-circle", alt: category.name %>
      <% else %>
        <img src="https://via.placeholder.com/40" class="rounded-circle" alt="No Icon">
      <% end %>
      </td>    
        <td><%= category.name %></td>
        <td><%= category.products.count %></td>
        <td>
          <%= link_to 'Show', category_path(category), class: "btn btn-sm btn-primary" %>
          <% if current_user&.admin? %>
            <%= link_to 'Edit', edit_category_path(category), class: "btn btn-sm btn-warning" %>
            <%= link_to 'Delete', category_path(category), method: :delete, data: { confirm: 'Are you sure?' }, class: "btn btn-sm btn-danger" %>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>




